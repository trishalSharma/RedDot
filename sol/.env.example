# ── Supabase ──────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# ── App URL ───────────────────────────────────────────────────
# Local dev:
VITE_APP_URL=http://localhost:3000
# Production (update after deploying to Vercel):
# VITE_APP_URL=https://sol-mars.vercel.app

# ── AI Mission Logs ───────────────────────────────────────────
# The Claude API key lives in Vercel env vars ONLY (never here).
# This just tells the client where the edge function lives.
# Leave as-is for local dev — Vite will proxy /api/* automatically.
VITE_AI_PROXY_URL=
